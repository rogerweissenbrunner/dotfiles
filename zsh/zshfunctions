#!/usr/bin/env zsh

fff() {
  [ -n "$1" ] || { echo "Usage: fff <pattern>"; return 1; }
  find . -iname "*$1*"
}

ggg() {
  grep -ri "$1" .;
}

extractfile() {
  if [ -f "$1" ]; then
    case "$1" in
      *.tar.bz2)          tar xjf "$1" ;;
      *.tar.gz)           tar xzf "$1" ;;
      *.bz2)              bunzip2 "$1" ;;
      *.rar)              unrar x "$1" ;;
      *.gz)               gunzip "$1" ;;
      *.tar)              tar xv "$1" ;;
      *.tbz2)             tar xjf "$1" ;;
      *.tgz)              tar xzf "$1" ;;
      *.zip)              unzip "$1" ;;
      *.Z)                uncompress "$1" ;;
      *.7z)               7z x "$1" ;;
      *)                  echo "'$1' cannot be extracted via extractfile()" ;;
    esac
  else
    echo "'$1' is not a valid file."
  fi
}

psgrep() {
  if [ -n "$1" ]; then
    echo "Grepping for processes matching $1..."
    ps aux | grep -i -- "$1" | grep -v grep
  else
    echo "!! Need name to grep for"
  fi
}

flip() {
  perl -C3 -Mutf8 -lpe '$_=reverse;y/a-zA-Z.['\'',({?!\"<_;鈥库亝鈭碶r/蓯q蓴p菨蔁苾丧谋删蕿|莎uodb晒s蕠n蕦蕧x蕩z蓯q蓴p菨蔁苾丧谋删蕿|莎uodb晒s蕠n蕦蕧x蕩z藱],'\'')}驴隆,>鈥矩涒亐鈦嗏埖\n/' <<< "$1"
}

pgstart() {
  if command -v systemctl >/dev/null 2>&1; then
    sudo systemctl start postgresql
    return $?
  fi

  if command -v pg_ctlcluster >/dev/null 2>&1; then
    sudo pg_ctlcluster --skip-systemctl-redirect "$(ls /etc/postgresql 2>/dev/null | sort -V | tail -n 1)" main start
    return $?
  fi

  echo "No PostgreSQL service manager found (systemctl/pg_ctlcluster)."
  return 1
}

pgstop() {
  if command -v systemctl >/dev/null 2>&1; then
    sudo systemctl stop postgresql
    return $?
  fi

  if command -v pg_ctlcluster >/dev/null 2>&1; then
    sudo pg_ctlcluster --skip-systemctl-redirect "$(ls /etc/postgresql 2>/dev/null | sort -V | tail -n 1)" main stop
    return $?
  fi

  echo "No PostgreSQL service manager found (systemctl/pg_ctlcluster)."
  return 1
}

pglog() {
  if command -v journalctl >/dev/null 2>&1; then
    journalctl -u postgresql -f
    return $?
  fi

  if [ -f /var/log/postgresql/postgresql.log ]; then
    tail -f /var/log/postgresql/postgresql.log
    return $?
  fi

  echo "No PostgreSQL logs found via journalctl or /var/log/postgresql/postgresql.log."
  return 1
}

psqlx() {
  if ! command -v psql >/dev/null 2>&1; then
    echo "psql command not found."
    return 1
  fi

  psql \
    --host "${PGHOST:-localhost}" \
    --port "${PGPORT:-5432}" \
    --username "${PGUSER:-developer}" \
    --dbname "${PGDATABASE:-development}"
}

lintsh() {
  if ! command -v shellcheck >/dev/null 2>&1; then
    echo "shellcheck command not found."
    return 1
  fi

  shellcheck "$@"
}

fmtsh() {
  if ! command -v shfmt >/dev/null 2>&1; then
    echo "shfmt command not found."
    return 1
  fi

  shfmt -w "$@"
}