#!/usr/bin/env zsh

plugins=( battery bundler colored-man-pages colorize command-not-found common-aliases dircycle dirhistory dotenv emoji encode64 gem
git git-extras github gitignore gpg-agent history-substring-search history jsontools lol man nmap node npm per-directory-history pow
rails rake-fast rake rand-quote redis-cli rsync ruby screen shrink-path ssh-agent sudo thor tmux tmuxinator urltools vi-mode
vim-interaction web-search zsh-completions zsh-syntax-highlighting)

source $HOME/.zshaliases
source $HOME/.zshfunctions

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"

if [ -x "$HOME/.rbenv/bin/rbenv" ]; then
  eval "$("$HOME/.rbenv/bin/rbenv" init - --no-rehash zsh)"
fi

if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

fpath+=$HOME/.oh-my-zsh/plugins/zsh-completions/src

source $ZSH/oh-my-zsh.sh

# Load after OMZ so LS_COLORS (from ~/.dircolors) exists before list-colors zstyle.
source $HOME/.zshoptions
